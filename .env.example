# RPC URL of the chain to deploy to (e.g. BSC, Ethereum)
RPC_URL=https://bsc-dataseed.binance.org/

# Deployer private key (no 0x prefix). Used by: forge script ... --broadcast
PRIVATE_KEY=

# Infinity CL PoolManager address on the target chain. Required for CLSwapFeeHook constructor.
# Example BSC mainnet: 0x...
CL_POOL_MANAGER=

# Optional: for forge script --verify (Etherscan/BSCScan)
# ETHERSCAN_API_KEY=
